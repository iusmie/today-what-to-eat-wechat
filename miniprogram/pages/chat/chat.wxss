/* pages/chat/chat.wxss */
.chat-container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.message {
  margin-bottom: 30rpx;
  padding: 20rpx;
  border-radius: 15rpx;
  max-width: 80%;
  word-wrap: break-word;
}

.message-user {
  background-color: #07c160;
  color: white;
  align-self: flex-end;
  margin-left: auto;
}

.message-bot {
  background-color: white;
  color: black;
  align-self: flex-start;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.timestamp {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}

.input-container {
  display: flex;
  padding: 20rpx;
  background-color: white;
  border-top: 1rpx solid #e5e5e5;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
}

.input-box {
  flex: 1;
  padding: 10rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.send-button {
  background-color: #07c160;
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}