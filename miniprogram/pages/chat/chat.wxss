/* 聊天页面 - 对齐 HTML 原型 (v2: 提高选择器优先级覆盖 app.wxss) */
/* --primary-orange: #FF8C42; --bg: #F7F8FA; --border-radius: 16px */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F8FA;
  box-sizing: border-box;
}

/* 聊天内容区 */
.chat-content {
  flex: 1;
  min-height: 0;
  padding: 30rpx 50rpx 56rpx 30rpx;
  box-sizing: border-box;
}

/* 欢迎页：内容居中，右侧预留充足空间 */
.chat-content-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 50rpx 80rpx 50rpx;
  min-height: auto;
}

/* 欢迎页：快捷入口卡片 - 右侧预留充足空间避免被裁切 */
.chat-page .welcome-cards {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  width: 100%;
  max-width: 520rpx;
  padding: 0 40rpx 0 40rpx;
  margin-right: 0;
}

.chat-page .quick-action-btn {
  width: 100%;
  background: #fff;
  border: 4rpx solid #e5e7eb;
  border-radius: 32rpx;
  padding: 28rpx 48rpx 28rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.chat-page .quick-action-btn:active {
  border-color: #FF8C42;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.15);
}

.chat-page .quick-action-btn .btn-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: #FFF5EB;
  border-radius: 20rpx;
}

.chat-page .quick-action-btn .btn-text {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.5;
  color: #333;
  font-weight: 500;
  text-align: left;
}

.chat-page .quick-action-btn .btn-arrow {
  font-size: 36rpx;
  line-height: 1;
  color: #999;
  flex-shrink: 0;
}

/* 消息行 */
.message-row {
  display: flex;
  margin-bottom: 40rpx;
  align-items: flex-start;
}

.message-row.user {
  flex-direction: row-reverse;
}

/* 头像 - HTML 36px */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.avatar.ai {
  background: #E3F2FD;
}

.avatar.user {
  background: #FF8C42;
  color: white;
}

/* 气泡 - HTML padding 12px 16px, border-radius 16px */
.bubble {
  max-width: 75%;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  line-height: 1.5;
  margin: 0 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.message-row.ai .bubble {
  background: #fff;
  color: #333;
}

.message-row.user .bubble {
  background: #FF8C42;
  color: white;
}

.bubble-text {
  display: block;
  word-break: break-word;
  white-space: pre-wrap;
}

.timestamp {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

.message-row.ai .timestamp {
  color: #999;
}

/* 交互式偏好选择卡片 */
.bubble-interactive {
  min-width: 280rpx;
  max-width: 85%;
}

.pref-card {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}

.pref-group {
  margin-bottom: 24rpx;
}

.pref-group:last-of-type {
  margin-bottom: 0;
}

.pref-title {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.pref-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pref-option {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  color: #333;
}

.pref-option.selected {
  background: #FF8C42;
  border-color: #FF8C42;
  color: #fff;
}

.pref-generate-btn {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 32rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
  background: #FF8C42;
  color: #fff;
}

.pref-generate-btn:active {
  opacity: 0.9;
}

/* 推荐卡片 - 参考截图样式 */
.bubble-recommend {
  min-width: 320rpx;
  max-width: 90%;
  padding: 0;
  overflow: hidden;
}

.rec-card {
  padding: 24rpx;
}

.rec-intro {
  display: block;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.rec-image-wrap {
  position: relative;
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  background: #eee;
}

.rec-image {
  width: 100%;
  height: 100%;
}

.rec-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.rec-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.rec-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.rec-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF8C42;
}

.rec-metrics {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.rec-metric {
  flex-shrink: 0;
}

.rec-nutrients {
  margin-bottom: 24rpx;
}

.rec-nut-title {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.rec-nut-bar {
  display: flex;
  height: 12rpx;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.rec-nut-seg {
  height: 100%;
}

.rec-nut-seg.carb {
  background: #FFD166;
}

.rec-nut-seg.protein {
  background: #06B6D4;
}

.rec-nut-seg.fat {
  background: #EF476F;
}

.rec-nut-legend {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #999;
}

.rec-actions {
  display: flex;
  gap: 20rpx;
}

.rec-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.rec-btn-secondary {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  color: #666;
}

.rec-btn-primary {
  background: #FF8C42;
  color: #fff;
}

.rec-btn:active {
  opacity: 0.9;
}

.rec-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-top: 16rpx;
}

/* 快捷入口 - 在 input-area-wrapper 上方，独立区块 */
.quick-actions-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 20rpx 30rpx 24rpx;
  background: #F7F8FA;
  border-top: 2rpx solid #eee;
  flex-shrink: 0;
}

.action-chip {
  flex-shrink: 0;
  background: #f5f5f5;
  border: 2rpx solid #eee;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #333;
  white-space: nowrap;
}

.action-chip:active {
  color: #FF8C42;
  background: #FFF5EB;
  border-color: #FF8C42;
}

/* 正在输入 */
.typing-bubble {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.typing-text {
  font-size: 26rpx;
  color: #999;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF8C42;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
  opacity: 0.6;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.6; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

/* 底部输入区 - 使用 .chat-page 覆盖 app.wxss 的 .input-box */
.chat-page .input-area-wrapper {
  background: #fff;
  padding: 24rpx 30rpx;
  padding-bottom: 60rpx;
  padding-bottom: calc(60rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #e5e7eb;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.chat-page .input-area-wrapper .input-box {
  background: #f5f5f5;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 30rpx;
  margin-right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: none;
}

.chat-page .input-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.chat-page .input-field {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.5;
  background: transparent;
}

.chat-page .send-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: 600;
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
  /* 有内容：可点击状态 */
  background: #FF8C42;
  color: #fff;
}

.chat-page .send-btn:active {
  opacity: 0.85;
}

.chat-page .send-btn-disabled {
  background: #f0f0f0;
  color: #ccc;
}
