/* AI流式交互聊天界面样式 - 优化版 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #f8f9ff 0%, #e6ecff 100%);
  padding: 20rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
.container::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
  z-index: 0;
}

/* 消息区域 */
.messages-container {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  z-index: 1;
}

/* 单条消息 */
.message {
  max-width: 80%;
  margin: 24rpx 0;
  padding: 28rpx 36rpx;
  border-radius: 28rpx;
  line-height: 1.6;
  font-size: 28rpx;
  word-break: break-word;
  animation: fadeIn 0.3s ease-out;
  position: relative;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
}

/* 用户消息 */
.message.user {
  align-self: flex-end;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-bottom-right-radius: 8rpx;
  margin-right: 20rpx;
}

/* AI助手消息 */
.message.bot {
  align-self: flex-start;
  background: white;
  color: #333;
  border-bottom-left-radius: 8rpx;
  margin-left: 20rpx;
  border: 1rpx solid #f0f4ff;
}

/* 消息气泡装饰 */
.message.user::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  clip-path: polygon(0 0, 100% 0, 100% 100%);
}

.message.bot::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: white;
  border-left: 1rpx solid #f0f4ff;
  border-top: 1rpx solid #f0f4ff;
  clip-path: polygon(0 0, 100% 0, 0 100%);
}

/* 消息时间戳 */
.timestamp {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: right;
  opacity: 0.8;
}

/* 输入区域 */
.input-container {
  display: flex;
  padding: 24rpx 0 32rpx;
  background: white;
  border-top: 2rpx solid #f0f4ff;
  align-items: center;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: auto;
  box-shadow: 0 -8rpx 24rpx rgba(0,0,0,0.05);
}

.input-wrapper {
  flex: 1;
  position: relative;
  margin-right: 20rpx;
}

.input-field {
  width: 100%;
  padding: 24rpx 40rpx 24rpx 32rpx;
  border: 2rpx solid #e1e5eb;
  border-radius: 50rpx;
  font-size: 28rpx;
  background: #f8fafc;
  outline: none;
  transition: all 0.3s ease;
}

.input-field:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

/* 发送按钮 */
.send-button {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.send-button::after {
  content: "➤";
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  position: relative;
  z-index: 2;
}

.send-button:hover {
  transform: scale(1.05);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.5);
}

.send-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.send-button:hover::before {
  opacity: 1;
}

/* 正在输入指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  background: white;
  border-radius: 28rpx;
  margin: 24rpx 0;
  align-self: flex-start;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.08);
  margin-left: 20rpx;
  border: 1rpx solid #f0f4ff;
}

.typing-text {
  color: #667eea;
  font-size: 26rpx;
  margin-right: 16rpx;
  font-weight: 500;
}

.typing-dots {
  display: flex;
  gap: 12rpx;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  background: #667eea;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
  opacity: 0.8;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

/* 菜品推荐卡片样式 */
.recommendation-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx 0;
  border-left: 6rpx solid #667eea;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.recommendation-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.recommendation-title::before {
  content: "🍽️";
  margin-right: 12rpx;
}

.recommendation-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.recommendation-steps {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.steps-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 12rpx;
}

.step-item {
  font-size: 24rpx;
  color: #555;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

/* 动画 */
@keyframes fadeIn {
  from { 
    opacity: 0; 
    transform: translateY(20rpx); 
  }
  to { 
    opacity: 1; 
    transform: translateY(0); 
  }
}

@keyframes typing {
  0%, 60%, 100% { 
    transform: translateY(0); 
    opacity: 0.8;
  }
  30% { 
    transform: translateY(-12rpx); 
    opacity: 1;
  }
}

/* 响应式设计 */
@media (max-width: 768rpx) {
  .container {
    padding: 10rpx;
  }
  
  .message {
    padding: 20rpx 28rpx;
    font-size: 26rpx;
    margin: 16rpx 0;
  }
  
  .input-field {
    padding: 20rpx 32rpx 20rpx 24rpx;
    font-size: 26rpx;
  }
  
  .send-button {
    width: 76rpx;
    height: 76rpx;
  }
  
  .recommendation-card {
    padding: 24rpx;
  }
  
  .recommendation-title {
    font-size: 28rpx;
  }
}

/* 状态指示器 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}