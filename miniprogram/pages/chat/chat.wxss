/* AI流式交互聊天界面样式 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4edf9 100%);
  padding: 20rpx;
}

/* 消息区域 */
.messages-container {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
}

/* 单条消息 */
.message {
  max-width: 80%;
  margin: 20rpx 0;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  line-height: 1.6;
  font-size: 28rpx;
  word-break: break-word;
  animation: fadeIn 0.3s ease-out;
}

/* 用户消息 */
.message.user {
  align-self: flex-end;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-bottom-right-radius: 8rpx;
}

/* AI助手消息 */
.message.bot {
  align-self: flex-start;
  background: white;
  color: #333;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

/* 消息时间戳 */
.timestamp {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: right;
}

/* 输入区域 */
.input-container {
  display: flex;
  padding: 20rpx 0;
  background: white;
  border-top: 2rpx solid #eee;
  align-items: center;
}

.input-wrapper {
  flex: 1;
  position: relative;
  margin-right: 20rpx;
}

.input-field {
  width: 100%;
  padding: 24rpx 40rpx 24rpx 32rpx;
  border: 2rpx solid #e1e5eb;
  border-radius: 50rpx;
  font-size: 28rpx;
  background: #f8fafc;
  outline: none;
}

/* 发送按钮 */
.send-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.send-button::after {
  content: "➤";
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

/* 正在输入指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: white;
  border-radius: 24rpx;
  margin: 20rpx 0;
  align-self: flex-start;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background: #667eea;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-10rpx); }
}

/* 响应式设计 */
@media (max-width: 768rpx) {
  .container {
    padding: 10rpx;
  }
  
  .message {
    padding: 16rpx 24rpx;
    font-size: 26rpx;
  }
  
  .input-field {
    padding: 16rpx 32rpx 16rpx 24rpx;
    font-size: 26rpx;
  }
  
  .send-button {
    width: 70rpx;
    height: 70rpx;
  }
}