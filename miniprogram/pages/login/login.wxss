/* 登录页面 - 高保真原型风格 */
/* 设计变量 */
/* --primary-orange: #FF8C42; --wechat-green: #07C160; --text-main: #333; --text-sub: #999 */

/* 登录页 - 对齐 HTML 原型 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5EB 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  box-sizing: border-box;
}

.login-content {
  width: 100%;
  max-width: 550rpx;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx; /* HTML subtitle margin-bottom 60px */
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: #FF8C42;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(255, 140, 66, 0.3);
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  line-height: 1.5;
  white-space: pre-line;
}

/* 登录按钮 - 微信绿，对齐 HTML */
.login-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.login-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.login-btn .btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 140, 66, 0.15);
  border-top: 4rpx solid #FF8C42;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: #999;
  font-size: 26rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 按钮下方协议说明 - 简洁样式 */
.agreement-footer {
  text-align: center;
  margin-top: 30rpx;
}

.agreement-footer-text {
  font-size: 24rpx;
  color: #cccccc;
}
