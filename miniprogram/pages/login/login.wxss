/* 现代化登录页面样式 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 欢迎区域 */
.welcome-section {
  text-align: center;
  margin-bottom: 80rpx;
  animation: slideInDown 0.6s ease-out;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: pulse 2s infinite;
}

.logo::after {
  content: "🍽️";
  font-size: 80rpx;
}

.title {
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  line-height: 1.5;
  opacity: 0.9;
}

/* 授权区域 */
.auth-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.login-button {
  width: 90%;
  max-width: 500rpx;
  height: 90rpx;
  background: white;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  border: none;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.25);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.login-button::before {
  content: "✓";
  font-size: 36rpx;
  color: #667eea;
}

.login-button:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.2);
}

.skip-button {
  width: 90%;
  max-width: 500rpx;
  height: 80rpx;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: white;
  transition: all 0.3s ease;
}

.skip-button:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

/* 隐私声明 */
.privacy-notice {
  text-align: center;
  margin-top: 60rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  line-height: 1.6;
  max-width: 500rpx;
  margin-left: auto;
  margin-right: auto;
}

.privacy-notice text {
  display: block;
  margin-bottom: 10rpx;
}

/* 加载区域 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-text {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top: 6rpx solid white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 动画 */
@keyframes slideInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式设计 */
@media (max-width: 768rpx) {
  .container {
    padding: 30rpx 20rpx;
  }
  
  .logo {
    width: 140rpx;
    height: 140rpx;
  }
  
  .title {
    font-size: 40rpx;
  }
  
  .subtitle {
    font-size: 26rpx;
  }
  
  .login-button {
    height: 80rpx;
    font-size: 30rpx;
  }
}