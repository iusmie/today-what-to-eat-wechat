<!-- 登录页面 - 高保真原型风格 -->
<view class="login-page">
  <view class="login-content">
    <!-- Logo 区域 -->
    <view class="logo-section">
      <view class="logo-wrapper">
        <text class="logo-icon">🍽️</text>
      </view>
      <text class="app-name">今天吃什么</text>
      <text class="app-slogan">AI 智能饮食顾问\n帮你解决每日最大的难题</text>
    </view>
    
    <!-- 登录按钮 -->
    <view wx:if="{{!isLoggingIn}}" class="login-btn wechat" hover-class="login-btn-hover" bindtap="onWechatMpLogin">
      <text class="btn-text">微信一键登录</text>
    </view>
    
    <!-- 加载状态 -->
    <view wx:if="{{isLoggingIn}}" class="loading-section">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在登录...</text>
    </view>
    
    <!-- 协议说明（按钮下方） -->
    <view wx:if="{{!isLoggingIn}}" class="agreement-footer">
      <text class="agreement-footer-text" bindtap="showPrivacyPolicy">登录即代表同意隐私协议</text>
    </view>
  </view>
</view>
