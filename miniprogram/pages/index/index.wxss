/* pages/index/index.wxss */
.container {
  padding: 40rpx;
  text-align: center;
}

.motto {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
  display: block;
}

.user-info {
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.nickname {
  font-size: 28rpx;
  font-weight: bold;
}

.buttons {
  margin-top: 60rpx;
}

.primary-button {
  background-color: #07c160;
  color: white;
  margin-bottom: 20rpx;
}

.secondary-button {
  background-color: #f5f5f5;
  color: #333;
  margin-bottom: 20rpx;
}

.login-prompt {
  margin-top: 60rpx;
}